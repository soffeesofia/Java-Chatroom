<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="server.ServerView">
  <grid id="27dc6" binding="serverPanel" layout-manager="GridLayoutManager" row-count="8" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
    <margin top="10" left="10" bottom="10" right="10"/>
    <constraints>
      <xy x="20" y="20" width="800" height="600"/>
    </constraints>
    <properties>
      <minimumSize width="-1" height="-1"/>
    </properties>
    <border type="none"/>
    <children>
      <scrollpane id="5f6e6">
        <constraints>
          <grid row="1" column="0" row-span="7" col-span="1" vsize-policy="7" hsize-policy="7" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties/>
        <border type="none"/>
        <children>
          <component id="90f63" class="javax.swing.JTextArea" binding="serverLogArea">
            <constraints/>
            <properties>
              <editable value="false"/>
              <lineWrap value="true"/>
              <margin top="0" left="5" bottom="0" right="0"/>
              <preferredSize width="600" height="600"/>
            </properties>
          </component>
        </children>
      </scrollpane>
      <component id="a1485" class="javax.swing.JTextArea" binding="onlineArea">
